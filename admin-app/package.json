{
  "name": "admin-app",
  "version": "1.0.0",
  "description": "Admin",
  "author": "D", 
  "main": "main.js",
  "scripts": {
    "start": "electron .",
        "dist": "electron-builder --win" 
  },
  "dependencies": {
      },

  "devDependencies": {
    "electron": "^28.0.0", 
    "electron-builder": "^26.0.12"
  },

  "build": {
    "appId": "id.go.kemendag.metrologi.antrian.admin", 
    "productName": "Admin", 
     "asar": false,
    "files": [
      "main.js",
      "package.json",
      "renderer/**/*", 
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}", 
      "!**/node_modules/.bin",
      "!**/*.{o,h,obj,lib,map,pdb,exp,ilk}"
      
    ],

    "directories": {
      "output": "dist_admin" 
    },
    "win": {
      "target": [
        {
          "target": "nsis", 
          "arch": ["x64"]
        }
      ],
      
      "icon": "renderer/assets/admin.png" 
    },
    
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}